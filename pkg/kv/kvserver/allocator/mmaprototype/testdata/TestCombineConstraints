# Empty constraints - only synthesized empty constraint
combine num-replicas=3 num-voters=0
----
 num-replicas=3 num-voters=3
 constraints:
   :3

# Single constraint - no combining needed
combine num-replicas=3 num-voters=0
constraint num-replicas=3 +region=us-west-1
----
 num-replicas=3 num-voters=3
 constraints:
   +region=us-west-1:3

# Combine duplicate constraints
# [+region=us-west-1]: 1 + [+region=us-west-1]: 1 => [+region=us-west-1]: 2
combine num-replicas=3 num-voters=1
constraint num-replicas=1 +region=us-west-1
constraint num-replicas=1 +region=us-west-1
----
 num-replicas=3 num-voters=1
 constraints:
   +region=us-west-1:2
   :1

# Combine empty constraints from user input and synthesized
# User specifies [:]:1, synthesis adds [:]:2 => combined [:]:3
combine num-replicas=3 num-voters=0
constraint num-replicas=1
----
 num-replicas=3 num-voters=3
 constraints:
   :3

# No duplicates - different constraints remain separate
combine num-replicas=5 num-voters=0
constraint num-replicas=1 +region=us-west-1
constraint num-replicas=2 +region=us-east-1
----
 num-replicas=5 num-voters=5
 constraints:
   +region=us-west-1:1
   +region=us-east-1:2
   :2

# Multiple constraints in conjunction - duplicates combined
combine num-replicas=5 num-voters=0
constraint num-replicas=1 +region=us-west-1 +zone=a
constraint num-replicas=2 +region=us-west-1 +zone=a
----
 num-replicas=5 num-voters=5
 constraints:
   +region=us-west-1,+zone=a:3
   :2

# Required vs prohibited not combined - different constraint types
combine num-replicas=3 num-voters=0
constraint num-replicas=1 +region=us-west-1
constraint num-replicas=1 -region=us-west-1
----
 num-replicas=3 num-voters=3
 constraints:
   +region=us-west-1:1
   -region=us-west-1:1
   :1

# Three duplicates combined: 1 + 2 + 1 = 4
combine num-replicas=5 num-voters=0
constraint num-replicas=1 +region=us-west-1
constraint num-replicas=2 +region=us-west-1
constraint num-replicas=1 +region=us-west-1
----
 num-replicas=5 num-voters=5
 constraints:
   +region=us-west-1:4
   :1

# Voter constraints - duplicates combined
# Normalization also narrows the all-replica constraints based on voter constraints
combine num-replicas=5 num-voters=3
constraint num-replicas=5
voter-constraint num-replicas=1 +region=us-west-1
voter-constraint num-replicas=1 +region=us-west-1
----
 num-replicas=5 num-voters=3
 constraints:
   +region=us-west-1:2
   :3
 voter-constraints:
   +region=us-west-1:2
   :1

# Empty voter constraints combined (the case from EdgeCases)
# User specifies [:]:1, synthesis adds [:]:2 => combined [:]:3
combine num-replicas=5 num-voters=3
voter-constraint num-replicas=1
----
 num-replicas=5 num-voters=3
 constraints:
   :5
 voter-constraints:
   :3
